# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: override which Claude models are used (defaults to claude-sonnet-4-6 / claude-haiku-4-5)
ANTHROPIC_MODEL_SMART=
ANTHROPIC_MODEL_FAST=

# ── OpenAI (used for Whisper transcription fallback in lib/transcribe.ts) ─────
OPENAI_API_KEY=

# ── Telegram bot ──────────────────────────────────────────────────────────────
# One bot, many tenants. Used for CRM-by-text and morning briefings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=VirtualCloserBot
# HMAC secret set in the Telegram Bot API setWebhook call.
TELEGRAM_WEBHOOK_SECRET=
# Fallback chat_id for tenants without their own telegram_chat_id set.
TELEGRAM_DEFAULT_CHAT_ID=

# ── Domain / routing ──────────────────────────────────────────────────────────
# Root apex domain (no subdomain). Used to extract the tenant slug from the host.
ROOT_DOMAIN=virtualcloser.com
# Fallback tenant slug used on localhost / *.vercel.app preview URLs.
DEFAULT_REP_SLUG=demo
# Full public URL of the app (used in email links, webhooks, etc.)
NEXT_PUBLIC_APP_URL=https://virtualcloser.com
NEXT_PUBLIC_BASE_URL=https://virtualcloser.com

# ── Auth / session ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Admin back-office password (protects /admin/*).
# Prefer ADMIN_PASSWORD_HASH (bcrypt hash) over plaintext ADMIN_PASSWORD.
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpass', 12))"
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# ── Cron auth ─────────────────────────────────────────────────────────────────
# Shared secret used by Vercel Cron to hit /api/cron/* endpoints.
# Authorization: Bearer <CRON_SECRET> header is required on all cron routes.
# Falls back to SESSION_SECRET if unset (not recommended).
CRON_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# From address — must match a verified Resend domain.
RESEND_FROM=Virtual Closer <hello@virtualcloser.com>
# Admin notification email for new bookings, dunning, etc.
ADMIN_EMAIL=
ADMIN_NOTIFY_EMAIL=

# ── Voice / RevRing ───────────────────────────────────────────────────────────
# Platform shared API key — used for all 'shared' billing-model calls.
REVRING_API_KEY=
# Master key for enterprise platform-trunk provisioning (enterprise only).
REVRING_MASTER_API_KEY=
# Default outbound caller ID for shared-billing calls.
REVRING_FROM_NUMBER=
# Set to 'true' or '1' to enable live outbound calls. Defaults to dry-run mode.
# Per-client live_enabled flag in client_integrations ALSO controls this.
VOICE_LIVE_ENABLED=
# Optional per-tenant secret for verifying RevRing webhook payloads (set in client_integrations).
# RevRing does not sign webhooks natively — leave blank unless you add signing in n8n/middleware.
REVRING_WEBHOOK_SECRET=
# Inbound phone numbers for specific use cases (optional; per-client config preferred)
REVRING_RECEPTIONIST_INBOUND_NUMBER=
REVRING_RECEPTIONIST_LIFE_INSURANCE_NUMBER=
REVRING_RECEPTIONIST_OUTBOUND_CONFIRM_NUMBER=
# Trainer agent IDs + numbers for platform-level roleplay trainers
REVRING_TRAINER_AGENT_NUMBER=
REVRING_TRAINER_2_AGENT_ID=
REVRING_TRAINER_2_AGENT_NUMBER=
REVRING_TRAINER_3_AGENT_ID=
REVRING_TRAINER_3_AGENT_NUMBER=
REVRING_TRAINER_4_AGENT_ID=
REVRING_TRAINER_4_AGENT_NUMBER=
# Tool secret for RevRing tool-calling webhook (e.g. book-appointment, get-available-slots)
REVRING_TOOL_SECRET=

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Stored per-client in client_integrations. Platform-level fallback not used.
# See lib/sms/twilioClient.ts for per-client config pattern.

# ── WAVV dialer ───────────────────────────────────────────────────────────────
# Stored per-client in client_integrations. Platform fallback:
WAVV_WEBHOOK_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Required for Google Calendar integration (confirmation calls, standup digest).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://virtualcloser.com/api/google/oauth/callback

# ── Cal.com ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CAL_BOOKING_URL=
# Optional HMAC secret for Cal.com → VC webhook verification.
CAL_WEBHOOK_SECRET=

# ── Fathom (meeting intelligence) ────────────────────────────────────────────
FATHOM_API_KEY=
FATHOM_WEBHOOK_SECRET=
FATHOM_PROSPECT_WEBHOOK_TOKEN=
# Comma-separated emails for host-side Fathom meeting enrichment
FATHOM_HOST_EMAILS=

# ── GoHighLevel (GHL) integration ────────────────────────────────────────────
# Platform-level fallback webhook secret. Per-client secret preferred (stored in client_integrations).
# Required in production if any GHL tenants haven't set a per-client secret.
GHL_WEBHOOK_SECRET=

# ── Furnace CRM integration ───────────────────────────────────────────────────
# Inbound webhook secret for lead pushes from Furnace.
FURNACE_INBOUND_SECRET=
# Outbound: VC pushes disposition updates to Furnace using LEADS_WEBHOOK_SECRET.
LEADS_WEBHOOK_SECRET=

# ── SakredCRM integration ─────────────────────────────────────────────────────
# HMAC-SHA256 secret shared between VC and SakredCRM for inbound webhook auth.
# Required: leaving this unset blocks all inbound SakredCRM webhooks in production.
SAKREDCRM_WEBHOOK_SECRET=
# URL VC calls to push call dispositions back to SakredCRM (POST after each call).
SAKREDCRM_SYNC_URL=

# ── Admin notifications ───────────────────────────────────────────────────────
ADMIN_TELEGRAM_CHAT_ID=

# ── Vercel / deployment ───────────────────────────────────────────────────────
VERCEL_API_TOKEN=

# ── Tavily (web search for agent tools) ──────────────────────────────────────
TAVILY_API_KEY=
