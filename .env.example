NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
# Root apex domain (no subdomain). Used to extract the tenant slug from the host.
