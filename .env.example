NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
# Telegram bot used for CRM-by-text and morning briefings. One bot, many tenants.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=VirtualCloserBot
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_CHAT_ID=
# Root apex domain (no subdomain). Used to extract the tenant slug from the host.
ROOT_DOMAIN=virtualcloser.com
# Fallback tenant slug used on localhost / *.vercel.app preview URLs.
DEFAULT_REP_SLUG=demo
# Shared secret used by Vercel Cron to hit the /api/cron/* endpoints.
CRON_SECRET=
# Stripe Payment Links (create one per tier in Stripe dashboard: combines
# one-time build fee + recurring subscription). Redirect success URL to
# https://virtualcloser.com/welcome?tier={tier}
STRIPE_LINK_SALESPERSON=
STRIPE_LINK_TEAM_BUILDER=
STRIPE_LINK_EXECUTIVE=
# Admin back-office password (protects /admin/*).
ADMIN_PASSWORD=
# Secret used to sign the cross-subdomain client session cookie.
# Generate with: openssl rand -hex 32. Falls back to CRON_SECRET if unset.
SESSION_SECRET=
# Resend API key — required for ALL outbound email (welcome, booking notifications, etc).
# Get from resend.com/api-keys. Without this, no emails are sent.
RESEND_API_KEY=
# From address for outbound email. Must match a verified Resend domain.
RESEND_FROM=Virtual Closer <hello@virtualcloser.com>
# Where to send new booking notification emails (defaults to jace@virtualcloser.com).
ADMIN_EMAIL=
# Your Telegram chat ID for admin booking pings. Get it by messaging @userinfobot.
ADMIN_TELEGRAM_CHAT_ID=
# Optional: shared secret between Cal.com webhook and this server (HMAC-SHA256).
# Set in Cal.com → Settings → Developer → Webhooks → Secret.
CAL_WEBHOOK_SECRET=
